    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "lru-cache": "^11.1.0",
    "pino": "^9.7.0",
    "pino-http": "^10.4.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/compression": "^1.8.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
