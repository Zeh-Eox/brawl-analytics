{
  "name": "proxy",
  "version": "1.0.0",
  "description": "Brawl Stars API proxy with computed analytics",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "nodemon --exec tsx src/server.ts",
    "server": "nodemon --exec tsx src/server.ts",
