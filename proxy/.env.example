# --- Server ---
NODE_ENV=development
PORT=5000
LOG_LEVEL=info

# --- Brawl Stars API ---
BRAWL_STARS_API_URL=https://api.brawlstars.com/v1
BRAWL_STARS_API_KEY=

# --- Upstream behaviour ---
UPSTREAM_TIMEOUT_MS=10000

# --- CORS ---
# "*" allows any origin (dev only). In prod, set a comma-separated list:
#   CORS_ORIGINS=https://app.example.com,https://www.example.com
CORS_ORIGINS=*

# --- Rate limiting (per IP, per window) ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# --- Cache ---
CACHE_MAX_ITEMS=2000

# --- Background capture (tracker) ---
# Where per-tag battle archives & trophy timelines are persisted.
DATA_DIR=./data
# Master switch for the background poller ("true" / "false").
TRACKER_ENABLED=true
# Sweep interval (ms) and pause between two tags within a sweep.
TRACKER_POLL_INTERVAL_MS=600000
TRACKER_POLL_SPACING_MS=1500
# Max actively-polled tags, and inactivity cutoff (days) before a tag is dropped.
TRACKER_MAX_TAGS=50
TRACKER_INACTIVE_DAYS=14
# Per-tag caps.
TRACKER_BATTLE_CAP=500
TRACKER_TIMELINE_CAP=2000
